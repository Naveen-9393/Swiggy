-- deep dive business analysis --
-- monthly order trends--
select
d.year,
d.month,
d.month_name,
count(*)as total_orders
from fact_swiggy f
join me_date d on f.date_id = d.date_id
group by
d.year,
d.month,
d.month_name
order by count(*)desc;

-- quaterly trend --
-- total orders in year to qurter wise --
select
d.year,
d.quarter,
count(*)as total_orders
from fact_swiggy f
join me_date d on f.date_id = d.date_id
group by
d.year,
d.quarter
order by count(*)desc;

-- yearly trend --
select
d.year,
count(*)as total_orders
from fact_swiggy f
join me_date d on f.date_id = d.date_id
group by d.year
order by count(*)desc;

-- orders by day of week(mon - sun)
SELECT  
DAYNAME(d.full_date) AS day_name,
COUNT(*) AS total_orders
FROM fact_swiggy f
JOIN me_date d ON f.date_id = d.date_id
GROUP BY  
DAYOFWEEK(d.full_date),
DAYNAME(d.full_date)
ORDER BY  
DAYOFWEEK(d.full_date);

-- top 10 cities by order volums --
SELECT  
l.city,
count(*)as total_orders FROM fact_swiggy f
JOIN me_location l ON l.location_id = f.location_id
GROUP BY  l.city
order by count(*)desc;

SELECT  
l.city,
sum(f.price_inr)as total_revenue  FROM fact_swiggy f
JOIN me_location l ON l.location_id = f.location_id
GROUP BY  l.city
order by sum(f.Price_inr)asc;

-- revenue contribution by states --
SELECT  
l.state,
sum(f.price_inr)as total_revenue  FROM fact_swiggy f
JOIN me_location l ON l.location_id = f.location_id
GROUP BY  l.state
order by sum(f.Price_inr)desc;

-- top 10 restaurants by orders --
SELECT 'TOP 10',
r.restaurant_name,
sum(f.price_inr)as total_revenue  FROM fact_swiggy f
JOIN me_restaurant r ON r.restaurant_id = f.restaurant_id
GROUP BY  r.restaurant_name
order by sum(f.Price_inr)desc;

-- top categories by orders volume --
SELECT 
c.category,
count(*)as total_orders  FROM fact_swiggy f
JOIN me_category c ON c.category_id = f.category_id
GROUP BY  c.category
order by sum(f.Price_inr)desc;

-- most order dish --
SELECT
d.dish_name,
count(*)as order_count  FROM fact_swiggy f
JOIN me_dish d ON d.dish_id = f.dish_id
GROUP BY  d.dish_name
order by order_count desc;

-- cuisine performance (order + avg rating) --
SELECT 
c.category,
count(*)as total_orders,avg(f.rating)as avg_rating  
FROM fact_swiggy f
JOIN me_category c ON c.category_id = f.category_id
GROUP BY  c.category
order by total_orders desc;

-- total orders by price range --
SELECT  
    CASE  
        WHEN price_inr < 100 THEN 'Under 100'
        WHEN price_inr BETWEEN 100 AND 199 THEN '100 - 199'
        WHEN price_inr BETWEEN 200 AND 299 THEN '200 - 299'
        WHEN price_inr BETWEEN 300 AND 399 THEN '300 - 399'
        WHEN price_inr BETWEEN 400 AND 499 THEN '400 - 499'
        ELSE '500+'
    END AS price_range,
    COUNT(*) AS total_orders
FROM fact_swiggy
GROUP BY  
    CASE  
        WHEN price_inr < 100 THEN 'Under 100'
        WHEN price_inr BETWEEN 100 AND 199 THEN '100 - 199'
        WHEN price_inr BETWEEN 200 AND 299 THEN '200 - 299'
        WHEN price_inr BETWEEN 300 AND 399 THEN '300 - 399'
        WHEN price_inr BETWEEN 400 AND 499 THEN '400 - 499'
        ELSE '500+'
    END
ORDER BY total_orders DESC;

-- rating count distribution(1-5) --
SELECT
rating,
count(*)as rating_count  FROM fact_swiggy f
GROUP BY rating
order by rating desc;


