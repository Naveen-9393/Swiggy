-- Delete Duplication --
DELETE s1
FROM swiggy s1
JOIN (SELECT id FROM (SELECT id,ROW_NUMBER() OVER (
PARTITION BY state, city, order_date,restaurant_name, location,category, dish_name,price_inr, rating, rating_count
ORDER BY id
) AS rn
FROM swiggy
) t
WHERE rn > 1
) s2 ON s1.id = s2.id;

