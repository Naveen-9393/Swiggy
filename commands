-- Fact Table --
create table fact_swiggy(
order_id int auto_increment primary key,
date_id int,
price_inr decimal(10,2),
rating decimal(4,2),
rating_count int,
location_id int,
restaurant_id int,
category_id int,
dish_id int,
foreign key(date_id) references me_date(date_id),
foreign key(location_id) references me_location(location_id),
foreign key(restaurant_id) references me_restaurant(restaurant_id),
foreign key(category_id) references me_category(category_id),
foreign key(dish_id) references me_dish(dish_id)
);

