-- fact_table --
INSERT INTO fact_swiggy(
    date_id,
    price_inr,
    rating,
    rating_count,
    location_id,
    restaurant_id,
    category_id,
    dish_id
)
SELECT
    dd.date_id,
    s.price_inr,
    s.rating,
    s.rating_count,
    dl.location_id,
    dr.restaurant_id,
    dc.category_id,
    dsh.dish_id
FROM swiggy s
JOIN me_date dd ON dd.full_date = s.order_date
JOIN me_location dl ON dl.state = s.state and dl.city = s.city and dl.location = s.location
JOIN me_restaurant dr ON dr.restaurant_name = s.restaurant_name
JOIN me_category dc ON dc.category = s.category
JOIN me_dish dsh ON dsh.dish_name = s.dish_name;

